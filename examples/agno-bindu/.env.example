# Required: an OpenRouter key (https://openrouter.ai/keys). The agno model call
# is the only thing that needs a key — reading the report findings does not.
OPENROUTER_API_KEY=sk-or-...        # pragma: allowlist secret

# Optional overrides.
BINDU_AGENT_MODEL=anthropic/claude-sonnet-4.5
BINDU_AGENT_NAME=bindu-dd-analyst
BINDU_AGENT_AUTHOR=bindu-examples@example.com
BINDU_AGENT_URL=http://localhost:3773

# Which report the analyst reads. Defaults to the bundled, 100%-synthetic
# "Project Atlas" golden report (docs/marketing/sample-report-atlas/). Point this
# at any `dd-agents run` output directory (e.g. its runs/latest) to analyze a
# real deal — the analyst reads <dir>/findings/merged/*.json (or a top-level
# findings_merged.json, as the bundled Atlas report ships).
# DD_REPORT_DIR=examples/project-atlas/sample_data_room/_dd/forensic-dd/runs/latest

# Network exposure. BINDU_EXPOSE=true opens a PUBLIC tunnel with your model key
# on the billing path. Leave off for local development. If you do expose, set a
# bearer token below — without it, the agent is reachable with no app-layer auth
# and every call spends your key and returns report contents.
# BINDU_EXPOSE=true
# BINDU_AUTH_TOKEN=

# CORS origins for browser clients (comma-separated). Defaults to the local dev
# origin; override for your own front-end.
# BINDU_CORS_ORIGINS=http://localhost:5173
