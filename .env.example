# ==============================================================================
# Due Diligence Agent SDK — Environment Variables
# ==============================================================================
# Copy this file to .env and uncomment/set the variables you need.
# Only ONE API access method is required (Option A, B, or C).
#
# dd-agents runs on the Claude Agent SDK. PROVIDER and MODEL are your choice,
# selected entirely by the env vars below (the SDK forwards them to the bundled
# Claude CLI; dd-agents adds no provider code). Native providers run Claude; an
# Anthropic-compatible gateway can serve ANY model (GPT, Gemini, …). See
# docs/user-guide/model-providers.md. Pick the option matching your account.

# --- LLM provider access (required — choose one) ---

# Option A: Anthropic API (recommended for new developers)
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: AWS Bedrock — set the routing flag AND your AWS credentials.
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_PROFILE=default
# AWS_REGION=us-east-1

# Option C: Google Vertex AI — set the routing flag AND your GCP project/region.
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project
# CLOUD_ML_REGION=us-east5

# Advanced: route through an Anthropic-Messages-compatible gateway/proxy.
# ANTHROPIC_BASE_URL=https://your-gateway.example.com
# ANTHROPIC_AUTH_TOKEN=...        # pragma: allowlist secret

# --- Model / provider tuning (optional) ---

# Clamp the per-call output token request. Set this if a gateway's backing
# model caps max_tokens lower than the CLI's default request (which would 400).
# Exported to the CLI as CLAUDE_CODE_MAX_OUTPUT_TOKENS by the LLM seam.
# DD_MAX_OUTPUT_TOKENS=4096

# Cost pricing for non-Claude / gateway models, per 1M tokens (JSON). Unknown
# models otherwise fall back to default rates and log a one-time warning.
# DD_MODEL_PRICING={"openai/gpt-4o": {"input": 2.5, "output": 10.0}}

# Pin the model for individual auxiliary reasoning paths (use the id form your
# endpoint expects). Specialists/synthesis use agent_models in the deal config.
# DD_QUERY_MODEL=
# DD_SEARCH_MODEL=
# DD_AUTOCONFIG_MODEL=
# DD_VISION_MODEL=

# --- Optional ---

# ChromaDB: persist vector search index to disk (default: memory-only)
# CHROMA_PERSIST_DIR=./chroma_data

# Logging level (default: INFO). Set to DEBUG for verbose pipeline output.
# LOG_LEVEL=INFO
