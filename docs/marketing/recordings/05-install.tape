# Due Diligence Agents — install one-liner (end-card terminal shot)
# Generates: ../assets/05-install.mp4
# Run from repo root: vhs docs/marketing/recordings/05-install.tape

Output docs/marketing/assets/05-install.mp4

Set FontSize 20
Set Width 1920
Set Height 1080
Set Theme "Catppuccin Mocha"
Set TypingSpeed 30ms
Set Padding 40
Set Framerate 30

Hide
Type "clear"
Enter
Show
Sleep 500ms

Type "# One line. Open-source. Runs locally."
Enter
Sleep 1.5s
Type ""
Enter
Type "pip install dd-agents"
Enter
Sleep 2s
Type "dd-agents version"
Enter
Sleep 2.5s
Type ""
Enter
Type "# Legal flags a risk. Finance another. We connect and cite."
Enter
Type "# github.com/zoharbabin/due-diligence-agents"
Enter
Sleep 4s
